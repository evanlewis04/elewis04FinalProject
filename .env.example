# Copy this file to .env and fill in your own values.
# Do NOT commit the real .env (it's in .gitignore).

# MongoDB Atlas connection string — see TODO.md step 2 for how to create one.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=

# Finnhub Stock API key — free tier from https://finnhub.io/register
FINNHUB_API_KEY=

# Optional. Defaults to 3000 locally. Render injects its own PORT — leave unset there.
PORT=3000
